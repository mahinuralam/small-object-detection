# ============================================================
# Small Object Detection — VisDrone
# Only source code, configs, and docs are tracked.
# Everything generated (data, weights, outputs, logs) is excluded.
# ============================================================


# ── DATASETS ────────────────────────────────────────────────
# VisDrone and any other raw/processed data (gigabytes)
dataset/
data/VisDrone*/
data/COCO/
data/raw/
data/processed/
*.zip
*.tar.gz
*.tar
*.rar
*.7z


# ── MODEL WEIGHTS & CHECKPOINTS ─────────────────────────────
*.pth
*.pt
*.ckpt
*.safetensors
*.h5
*.keras
*.pb
*.onnx
saved_model/


# ── TRAINING / EVALUATION OUTPUTS ───────────────────────────
results/
outputs/
runs/
checkpoints/
logs/


# ── GENERATED IMAGES & VIDEOS ───────────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.mp4
*.avi
*.mov


# ── EXPERIMENT TRACKING ─────────────────────────────────────
wandb/
mlruns/
mlartifacts/
tensorboard/
events.out.tfevents.*
*.log
*.log.*


# ── PYTHON CACHE & BUILD ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST
wheels/


# ── VIRTUAL ENVIRONMENTS ────────────────────────────────────
venv/
.venv/
env/
ENV/
conda_env/


# ── JUPYTER ─────────────────────────────────────────────────
.ipynb_checkpoints/
*-checkpoint.ipynb


# ── TEMP / CACHE ────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.backup
*.cache
cache/
matplotlib-*/
pymp-*/


# ── IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
*.iml
*.swp
*.swo
*~


# ── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
[Dd]esktop.ini
.directory
.Trash-*


# ── PROFILING / COVERAGE ────────────────────────────────────
